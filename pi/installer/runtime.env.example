# Installer picks Ollama or none.
LOCAL_BACKEND=ollama
LOCAL_MODEL=qwen3.5:2b

OLLAMA_BASE=http://127.0.0.1:11434
# Only if you run llama.cpp.
# LLAMACPP_BASE=http://127.0.0.1:8080

# Gateway URLs
GATEWAY_URL=https://vritti.dev/v1/chat
GATEWAY_VOICE_WS_URL=wss://vritti.dev/v1/voice/ws
GATEWAY_DEVICE_TOKEN=replace_with_device_token
GATEWAY_REGISTER_URL=https://vritti.dev/v1/device/register
# Optional bootstrap hint.
# GATEWAY_BOOTSTRAP_SECRET=
DEVICE_ID=pi-001

# Prefer gateway.
GATEWAY_FIRST=true
# Local-only mode.
FORCE_LOCAL_ONLY=false
NUM_CTX=1024
VOICE_STREAM_SAMPLE_RATE=16000
VOICE_STREAM_FRAME_MS=80
VOICE_PLAYBACK_BUFFER_MS=120

# Optional remote face UI.
# Leave unset to use deployed/local face-ui.
# VRITTI_FACE_UI_SOURCE=github
# Optional raw URL.
# Example: raw GitHub index.html URL
