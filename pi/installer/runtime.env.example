# Local model backend: installer can provision Ollama or disable local models entirely
LOCAL_BACKEND=ollama
LOCAL_MODEL=qwen3.5:2b

OLLAMA_BASE=http://127.0.0.1:11434
# Optional legacy local backend. Installer does not provision llama.cpp.
# LLAMACPP_BASE=http://127.0.0.1:8080

# Gateway for chat, STT, and TTS
GATEWAY_URL=https://gateway.vritti.dev/v1/chat
GATEWAY_VOICE_WS_URL=wss://gateway.vritti.dev/v1/voice/ws
GATEWAY_DEVICE_TOKEN=replace_with_device_token
GATEWAY_REGISTER_URL=https://gateway.vritti.dev/v1/device/register
GATEWAY_BOOTSTRAP_SECRET=replace_with_bootstrap_secret
DEVICE_ID=pi-001

# Try gateway first, local model as backup
GATEWAY_FIRST=true
# Skip gateway, use only local model
FORCE_LOCAL_ONLY=false
NUM_CTX=1024
VOICE_STREAM_SAMPLE_RATE=16000
VOICE_STREAM_FRAME_MS=80
VOICE_PLAYBACK_BUFFER_MS=120

# Optional remote face UI source.
# Leave commented to prefer deployed /opt/face-ui or repo face-ui.
# VRITTI_FACE_UI_SOURCE=github
# Optional raw URL override
# Example: raw GitHub index.html URL
