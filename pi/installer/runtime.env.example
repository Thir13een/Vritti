# Local model backend: ollama or llamacpp
LOCAL_BACKEND=llamacpp
LOCAL_MODEL=qwen3.5:2b

OLLAMA_BASE=http://127.0.0.1:11434
LLAMACPP_BASE=http://127.0.0.1:8080

# Gateway
GATEWAY_URL=https://your-gateway-domain/v1/chat
GATEWAY_DEVICE_TOKEN=replace_with_device_token
GATEWAY_REGISTER_URL=https://your-gateway-domain/v1/device/register
GATEWAY_BOOTSTRAP_SECRET=replace_with_bootstrap_secret
DEVICE_ID=pi-001

# Try gateway first, local model as backup
GATEWAY_FIRST=true
# Skip gateway, use only local model
FORCE_LOCAL_ONLY=false
NUM_CTX=1024
