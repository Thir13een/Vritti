# Local model backend: ollama or llamacpp
LOCAL_BACKEND=llamacpp
LOCAL_MODEL=qwen3.5:2b

OLLAMA_BASE=http://127.0.0.1:11434
LLAMACPP_BASE=http://127.0.0.1:8080

# Gateway fallback
GATEWAY_URL=https://your-gateway-domain/v1/fallback
GATEWAY_DEVICE_TOKEN=replace_with_device_token
GATEWAY_REGISTER_URL=https://your-gateway-domain/v1/device/register
GATEWAY_BOOTSTRAP_SECRET=replace_with_bootstrap_secret
DEVICE_ID=pi-001

# When true (default), every response is sent to the gateway for polish via Sarvam/OpenRouter API. Set false to use only local model.
ALWAYS_USE_GATEWAY=true
# Set true to force server polish even when ALWAYS_USE_GATEWAY is false (for testing).
FORCE_FALLBACK=false
NUM_CTX=1024
