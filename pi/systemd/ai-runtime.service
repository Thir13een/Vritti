[Unit]
Description=Pi AI Runtime
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/ai-runtime
EnvironmentFile=/opt/ai-runtime/.env
ExecStart=/opt/ai-runtime/.venv/bin/uvicorn server:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/ai-runtime
MemoryMax=512M

[Install]
WantedBy=multi-user.target
